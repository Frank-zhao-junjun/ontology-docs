      {
        "id": "scenario-mts",
        "name": "面向库存生产",
        "nameEn": "MTS",
        "projectId": "manifest-compile-demo"
      }
    ],
    "entities": [
      {
        "id": "production-order",
        "name": "生产订单",
        "nameEn": "ProductionOrder",
        "projectId": "manifest-compile-demo",
        "businessScenarioId": "scenario-mts",
        "entityRole": "aggregate_root",
        "isAggregateRoot": true,
        "attributes": [
          {
            "id": "attr-order-id",
            "name": "生产订单号",
            "nameEn": "order_id",
            "dataType": "string",
            "required": true
          }
        ],
        "relations": []
      },
      {
        "id": "operation",
        "name": "工序",
        "nameEn": "Operation",
