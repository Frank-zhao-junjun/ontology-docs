        "id": "evt-order-released",
        "name": "生产订单已下达",
        "nameEn": "ProductionOrderReleased",
        "entity": "production-order",
        "trigger": "custom",
        "payload": [{ "field": "order_id" }]
      }
    ],
    "subscriptions": [],
