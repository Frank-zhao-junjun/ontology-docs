    "createdAt": "2026-06-04T00:00:00.000Z",
    "updatedAt": "2026-06-04T00:00:00.000Z"
  },
  "behaviorModel": {
    "id": "bm-compile",
    "name": "行为模型",
    "version": "1.0.0",
    "domain": "domain-manufacturing",
    "stateMachines": [
      {
        "id": "sm-production-order",
        "name": "生产订单生命周期",
        "entity": "production-order",
        "statusField": "status",
        "states": [
          { "id": "st-created", "name": "CREATED", "isInitial": true },
          { "id": "st-released", "name": "RELEASED" }
        ],
        "transitions": [
          {
            "id": "tr-release",
            "name": "下达",
            "from": "st-created",
            "to": "st-released",
            "trigger": "manual"
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "action-release-order",
        "name": "生产订单下达",
        "nameEn": "ReleaseProductionOrder",
        "targetEntityId": "production-order",
        "actionType": "custom",
        "ruleRefs": ["rule-kitting"],
        "publishesEventIds": ["evt-order-released"]
      }
    ],
    "createdAt": "2026-06-04T00:00:00.000Z",
    "updatedAt": "2026-06-04T00:00:00.000Z"
  },
  "ruleModel": {
    "id": "rm-compile",
    "name": "规则模型",
    "version": "1.0.0",
    "domain": "domain-manufacturing",
    "rules": [
      {
        "id": "rule-kitting",
        "name": "物料齐套校验",
        "type": "cross_entity_validation",
        "entity": "production-order",
        "condition": { "type": "expression", "expression": "true" },
        "errorMessage": "物料未齐套"
      }
    ],
    "createdAt": "2026-06-04T00:00:00.000Z",
    "updatedAt": "2026-06-04T00:00:00.000Z"
  },
  "processModel": null,
  "eventModel": {
